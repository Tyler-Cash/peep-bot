{
  "name": "peep-bot-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "MCP server exposing AST and search tools over the Peep Bot codebase",
  "type": "module",
  "bin": {
    "peep-bot-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "tsc && vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ast-grep/cli": "^0.32.3",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@vscode/ripgrep": "^1.18.0",
    "fast-xml-parser": "^4.5.0",
    "pg": "^8.13.1",
    "typescript-language-server": "^4.3.3",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageserver-protocol": "^3.17.5",
    "yaml": "^2.8.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.10",
    "typescript": "^5.6.3",
    "vitest": "^3.0.0"
  }
}
