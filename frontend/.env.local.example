# mock = MSW intercepts /api calls (no homelab needed)
# live = fetch against NEXT_PUBLIC_API_BASE
NEXT_PUBLIC_API_MODE=mock
NEXT_PUBLIC_API_BASE=http://localhost:8080/api

# Server-side Google Maps Platform key (Places API (New) enabled).
# NOT prefixed with NEXT_PUBLIC — never sent to the browser.
# In mock mode or when unset, location falls back to static mock suggestions.
# Restrict the key by server IP or referrer in Google Cloud Console before shipping.
GOOGLE_MAPS_KEY=

# Upstash Redis — used for Places API rate limiting (300ms window + 50/hr cap).
# Create a free database at https://console.upstash.com and copy the REST credentials.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# OpenTelemetry — server-side traces exported by @vercel/otel (src/instrumentation.ts).
# Read by the Next.js server runtime only (no NEXT_PUBLIC_ prefix → never sent to the browser).
#
# On Vercel the public collector endpoint + protocol are baked into
# src/instrumentation.ts, so the ONLY var to configure in the Vercel project is
# the secret ingest auth header:
#   OTEL_EXPORTER_OTLP_HEADERS = Authorization=Basic <base64 of user:password>
#
# Locally these stay unset so `npm run dev` does not ship traces. To exercise
# export from local dev, uncomment all three (endpoint is public, header is secret):
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otel.tylercash.dev
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# OTEL_EXPORTER_OTLP_HEADERS=
#
# Browser RUM (src/lib/otel/web.ts): set to "1" to enable client-side tracing —
# per-fetch + document-load spans, and W3C traceparent propagation to the backend
# so frontend and backend share one trace. Browser spans POST to the same-origin
# /api/traces proxy (which reuses OTEL_EXPORTER_OTLP_HEADERS server-side), so no
# secret reaches the client. Off unless explicitly set to "1".
NEXT_PUBLIC_OTEL_BROWSER_ENABLED=

