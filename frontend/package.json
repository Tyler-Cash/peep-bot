{
  "name": "peepbot-frontend",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "msw:init": "msw init public/ --save",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:live": "E2E_LIVE=1 playwright test --project=live",
    "test:e2e:all": "ALL_BROWSERS=1 E2E_LIVE=1 playwright test",
    "test:e2e:ui": "playwright test --ui",
    "codegen": "openapi-ts && sed -i \"s/z\\.coerce\\.bigint()\\.min(BigInt('[^']*'), { error: '[^']*' })\\.max(BigInt('[^']*'), { error: '[^']*' })/z.number()/g\" src/lib/api/generated/zod.gen.ts && sed -i \"s/\\.optional()$/.nullable().optional()/g; s/\\.optional(),/.nullable().optional(),/g\" src/lib/api/generated/zod.gen.ts",
    "codegen:check": "npm run codegen && git diff --exit-code src/lib/api/generated"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/otel": "^2.1.2",
    "@vercel/speed-insights": "^2.0.0",
    "d3": "^7.9.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "swr": "^2.2.5",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.97.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/d3": "^7.4.3",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.12.0",
    "eslint-config-next": "^15.1.0",
    "jsdom": "^29.1.0",
    "msw": "^2.4.9",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^6.0.0",
    "vitest": "^4.1.5"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
