<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <logger name="dev.tylercash.event" level="INFO" />
    <logger name="org.springframework.security" level="WARN" />
    <logger name="net.dv8tion.jda" level="WARN" />

    <springProfile name="local">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level [%X{requestId:-}/%X{traceId:-}] user=%X{userId:-anon} %logger{36} - %msg%n</pattern>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="CONSOLE" />
        </root>
    </springProfile>

    <springProfile name="!local">
        <!-- Plain text on stdout so `docker logs` / `kubectl logs` stays readable, but
             deliberately not JSON: nothing should re-parse stdout into structured logs.
             The OTLP appender below is the single authoritative path to SigNoz. -->
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level [%X{traceId:-}] eventId=%X{eventId:-} %logger{36} - %msg%n</pattern>
            </encoder>
        </appender>
        <!-- Forwards LogRecords over OTLP and stamps the active Span's trace_id/span_id on
             them as top-level attributes. captureMdcAttributes promotes every MDC key
             (eventId, guildId, channelId, interactionId, …) to an indexed log attribute,
             so SigNoz sees them as fast filters rather than buried in the body. -->
        <appender name="OTEL" class="io.opentelemetry.instrumentation.logback.appender.v1_0.OpenTelemetryAppender">
            <captureExperimentalAttributes>true</captureExperimentalAttributes>
            <captureMdcAttributes>*</captureMdcAttributes>
        </appender>
        <root level="INFO">
            <appender-ref ref="CONSOLE" />
            <appender-ref ref="OTEL" />
        </root>
    </springProfile>
</configuration>
